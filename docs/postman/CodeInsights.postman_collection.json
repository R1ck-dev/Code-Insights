              }
            }
          ]
        },
        {
          "name": "Alterar visibilidade do perfil (PATCH /api/usuarios/me/visibilidade)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"publico\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/me/visibilidade",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "me", "visibilidade"]
            },
            "description": "Torna o perfil publico (true) ou privado (false)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sem conteudo (204)', function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Perfil publico por id (GET /api/usuarios/{id})",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/{{usuarioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "{{usuarioId}}"]
            },
            "description": "Rota publica: retorna dados publicos do usuario. Usamos o proprio `usuarioId` como exemplo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OK (200)', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Desafios",
      "description": "CRUD de desafios e portfolio publico por autor. A exclusao fica na pasta '5. Limpeza'.",
      "item": [
        {
          "name": "Criar desafio (POST /api/desafios)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Two Sum\",\n  \"enunciado\": \"Dado um array de inteiros e um alvo, retornar os indices dos dois numeros que somam o alvo.\",\n  \"plataformaOrigem\": \"LeetCode\",\n  \"identificadorExterno\": \"two-sum\",\n  \"urlExterna\": \"https://leetcode.com/problems/two-sum/\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/desafios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios"]
            },
            "description": "Cria um desafio. Apenas `titulo` e obrigatorio; `enunciado`, `plataformaOrigem`, `identificadorExterno` e `urlExterna` sao opcionais. Salva `desafioId` e `autorId`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Criado (201)', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "  const d = pm.response.json();",
                  "  if (d && d.id) { pm.collectionVariables.set('desafioId', d.id); console.log('desafioId = ' + d.id); }",
                  "  if (d && d.autorId) { pm.collectionVariables.set('autorId', d.autorId); }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar meus desafios (GET /api/desafios)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/desafios?pagina=0&tamanho=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios"],
              "query": [
                { "key": "pagina", "value": "0" },
                { "key": "tamanho", "value": "10" }
              ]
            },
            "description": "Lista paginada dos desafios do usuario autenticado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OK (200)', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar desafios publicos do autor (GET /api/desafios/autor/{id})",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/desafios/autor/{{autorId}}?pagina=0&tamanho=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios", "autor", "{{autorId}}"],
              "query": [
                { "key": "pagina", "value": "0" },
                { "key": "tamanho", "value": "10" }
              ]
            },
            "description": "Rota publica: portfolio com os desafios PUBLICOS de um autor."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OK (200)', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Detalhe do desafio (GET /api/desafios/{id})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/desafios/{{desafioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios", "{{desafioId}}"]
            },
            "description": "Detalhe de um desafio (proprio ou publico). Guarda o `enunciado` atual em `enunciadoAntes` para validar, mais adiante, que o PATCH parcial nao o sobrescreve."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OK (200)', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json();",
                  "  if (d && typeof d.enunciado !== 'undefined') {",
                  "    pm.collectionVariables.set('enunciadoAntes', String(d.enunciado));",
                  "    console.log('enunciadoAntes guardado para checagem de PATCH parcial.');",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Atualizar desafio (PATCH /api/desafios/{id})",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Two Sum (revisado)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/desafios/{{desafioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios", "{{desafioId}}"]
            },
            "description": "PATCH parcial (apenas o autor): envia somente o `titulo`. Campos omitidos (enunciado, plataformaOrigem, identificadorExterno, urlExterna) sao preservados pelo backend - campo ausente significa 'nao alterar'. A request seguinte confirma isso."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sem conteudo (204)', function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Detalhe pos-atualizacao - valida PATCH parcial (GET /api/desafios/{id})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/desafios/{{desafioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "desafios", "{{desafioId}}"]
            },
            "description": "Reconsulta o desafio apos o PATCH parcial e prova que apenas o `titulo` mudou, enquanto o `enunciado` (campo omitido no PATCH) foi preservado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OK (200)', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json();",
                  "  pm.test('PATCH parcial alterou o titulo', function () {",
