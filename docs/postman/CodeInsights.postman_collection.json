              "mode": "raw",
              "raw": "{\n  \"username\": \"{{testeUsername}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "me"]
            },
            "description": "Atualiza o nome de usuario. Mantemos o mesmo valor para ser idempotente em re-execucoes (mudar para um username ja em uso retorna 400)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
